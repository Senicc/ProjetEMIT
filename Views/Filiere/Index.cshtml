@model IEnumerable<ProjetEMIT.Models.Filiere>

@{
    ViewData["Title"] = "Gestion des Fili&egrave;res";
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h2 class="text-2xl font-bold text-gray-800">
                <i class="fas fa-graduation-cap text-purple-600 mr-2"></i> Fili&egrave;res
            </h2>
            <p class="text-sm text-gray-500 mt-1">G&eacute;rez les fili&egrave;res d'enseignement de l'&eacute;tablissement.</p>
        </div>
        <a asp-action="Create" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium shadow-md shadow-purple-500/20 transition-all flex items-center text-sm">
            <i class="fas fa-plus mr-2"></i> Ajouter
        </a>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                        <th class="py-4 px-6 font-semibold">Code</th>
                        <th class="py-4 px-6 font-semibold">Nom</th>
                        <th class="py-4 px-6 font-semibold">Mati&egrave;res</th>
                        <th class="py-4 px-6 font-semibold">Classes</th>
                        <th class="py-4 px-6 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-4 px-6">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-purple-50 text-purple-700 border border-purple-200">
                                    @item.Code
                                </span>
                            </td>
                            <td class="py-4 px-6 text-sm font-medium text-gray-800">@item.Nom</td>
                            <td class="py-4 px-6 text-sm text-gray-500">@item.Matieres.Count</td>
                            <td class="py-4 px-6 text-sm text-gray-500">@item.Classes.Count</td>
                            <td class="py-4 px-6 text-right space-x-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline" onsubmit="return confirm('Supprimer cette fili&egrave;re ?');">
                                    <button type="submit" class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-red-600 hover:bg-red-50 transition-colors">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
