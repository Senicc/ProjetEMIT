@model EnseignantViewModel
@{
    ViewData["Title"] = "Nouvel enseignant";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var matieres = ViewBag.Matieres as IEnumerable<ProjetEMIT.Models.Matiere>;
}

<h2 class="mb-4">Nouvel enseignant</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Nom" class="form-label"></label>
            <input asp-for="Nom" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Prenom" class="form-label"></label>
            <input asp-for="Prenom" class="form-control" />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Telephone" class="form-label"></label>
        <input asp-for="Telephone" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Specialite" class="form-label"></label>
        <input asp-for="Specialite" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Matières</label>
        @if (matieres != null)
        {
            foreach (var m in matieres)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedMatieresIds" value="@m.Id"
                           id="m_@m.Id" @(Model.SelectedMatieresIds.Contains(m.Id) ? "checked" : null) />
                    <label class="form-check-label" for="m_@m.Id">@m.Code — @m.Nom</label>
                </div>
            }
        }
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
