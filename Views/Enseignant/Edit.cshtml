@model ProjetEMIT.ViewModels.EnseignantViewModel

@{
    ViewData["Title"] = "Modifier un Enseignant";
}

<div class="max-w-3xl mx-auto bg-white shadow-xl rounded-xl border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-yellow-500 to-yellow-600 p-6 text-white">
        <h2 class="text-2xl font-bold flex items-center">
            <i class="fas fa-user-edit mr-3"></i> Modifier : @Model.Prenom @Model.Nom
        </h2>
        <p class="text-yellow-50 mt-2 opacity-90">Mettez &agrave; jour le dossier de cet enseignant.</p>
    </div>

    <div class="p-8">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium bg-red-50 p-3 rounded-lg border border-red-200"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Nom -->
                <div>
                    <label asp-for="Nom" class="block text-sm font-semibold text-gray-700 mb-2">Nom</label>
                    <input asp-for="Nom" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 transition-all" required />
                    <span asp-validation-for="Nom" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Pr&eacute;nom -->
                <div>
                    <label asp-for="Prenom" class="block text-sm font-semibold text-gray-700 mb-2">Pr&eacute;nom</label>
                    <input asp-for="Prenom" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 transition-all" required />
                    <span asp-validation-for="Prenom" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-2">Adresse E-mail</label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 transition-all" required />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- T&eacute;l&eacute;phone -->
                <div>
                    <label asp-for="Telephone" class="block text-sm font-semibold text-gray-700 mb-2">T&eacute;l&eacute;phone</label>
                    <input asp-for="Telephone" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 transition-all" />
                    <span asp-validation-for="Telephone" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Sp&eacute;cialit&eacute; -->
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="Specialite" class="block text-sm font-semibold text-gray-700 mb-2">Sp&eacute;cialit&eacute;</label>
                    <input asp-for="Specialite" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 transition-all" required />
                    <span asp-validation-for="Specialite" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="mt-8 flex items-center justify-end space-x-4 pt-6 border-t border-gray-100">
                <a asp-action="Index" class="px-6 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                    Annuler
                </a>
                <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-yellow-600 hover:bg-yellow-700 rounded-lg shadow-lg shadow-yellow-500/30 transition-all flex items-center">
                    <i class="fas fa-save mr-2"></i> Mettre &agrave; jour
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
