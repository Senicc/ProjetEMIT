@model ProjetEMIT.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Inscription - EMIT";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .bg-animated {
            background: linear-gradient(-45deg, #0f172a, #1e3a8a, #312e81, #0891b2);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
        }
        @@keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
    </style>
</head>
<body class="bg-animated min-h-screen flex items-center justify-center p-4 py-12">

    <div class="w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden glass-panel">
        
        <!-- Header -->
        <div class="bg-gradient-to-r from-blue-700 to-indigo-800 p-8 text-center text-white relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1541339907198-e08756dedf3f?ixlib=rb-4.0.3')] bg-cover bg-center opacity-10 mix-blend-overlay"></div>
            <div class="relative z-10">
                <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center text-blue-700 text-3xl shadow-lg mx-auto mb-4">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h2 class="text-3xl font-bold mb-2">Cr&eacute;er un compte</h2>
                <p class="text-blue-100 opacity-90">Rejoignez la plateforme EMIT</p>
            </div>
        </div>

        <!-- Form -->
        <div class="p-8 sm:p-10">
            <form asp-action="Register" method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 bg-red-50 p-4 rounded-lg text-sm border border-red-100"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Nom -->
                    <div class="space-y-2">
                        <label asp-for="Nom" class="text-sm font-semibold text-gray-700 block">Nom</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-user text-gray-400"></i>
                            </div>
                            <input asp-for="Nom" class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all text-gray-700" placeholder="Ex: Dupont" />
                        </div>
                        <span asp-validation-for="Nom" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <!-- Pr&eacute;nom -->
                    <div class="space-y-2">
                        <label asp-for="Prenom" class="text-sm font-semibold text-gray-700 block">Pr&eacute;nom</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="far fa-user text-gray-400"></i>
                            </div>
                            <input asp-for="Prenom" class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all text-gray-700" placeholder="Ex: Jean" />
                        </div>
                        <span asp-validation-for="Prenom" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- Email -->
                <div class="space-y-2">
                    <label asp-for="Email" class="text-sm font-semibold text-gray-700 block">Adresse E-mail</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-gray-400"></i>
                        </div>
                        <input asp-for="Email" type="email" class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all text-gray-700" placeholder="prenom.nom@emit.edu" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Password -->
                    <div class="space-y-2">
                        <label asp-for="Password" class="text-sm font-semibold text-gray-700 block">Mot de passe</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400"></i>
                            </div>
                            <input asp-for="Password" type="password" class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all text-gray-700" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" />
                        </div>
                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="space-y-2">
                        <label asp-for="ConfirmPassword" class="text-sm font-semibold text-gray-700 block">Confirmer</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-check-circle text-gray-400"></i>
                            </div>
                            <input asp-for="ConfirmPassword" type="password" class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition-all text-gray-700" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                

                <button type="submit" class="w-full py-4 px-4 mt-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl shadow-lg shadow-blue-600/30 transition-all flex items-center justify-center space-x-2">
                    <span>S'inscrire</span>
                    <i class="fas fa-check text-sm"></i>
                </button>
            </form>
            
            <div class="mt-8 text-center text-sm text-gray-500 pt-6 border-t border-gray-100">
                Vous avez d&eacute;j&agrave; un compte ? <a href="@Url.Action("Login", "Account")" class="text-blue-600 font-semibold hover:underline">Connectez-vous</a>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

