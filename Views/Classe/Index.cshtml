@model IEnumerable<ProjetEMIT.Models.Classe>

@{
    ViewData["Title"] = "Gestion des Classes";
    var isAdminOrResp = User.IsInRole("Administrateur") || User.IsInRole("ResponsablePedagogique");
}

<div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
    <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-gray-50/50">
        <div>
            <h2 class="text-xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-users mr-2 text-orange-600"></i> Classes &amp; Fili&egrave;res
            </h2>
            <p class="text-sm text-gray-500 mt-1">G&eacute;rez les groupes d'&eacute;tudiants par niveau et par fili&egrave;re.</p>
        </div>
        
        @if (isAdminOrResp)
        {
            <a asp-action="Create" class="bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded-lg font-medium shadow-md shadow-orange-500/20 transition-all flex items-center">
                <i class="fas fa-plus mr-2"></i> Ajouter une Classe
            </a>
        }
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider border-b border-gray-200">
                    <th class="p-4 font-medium">Nom de la Classe</th>
                    
                    <th class="p-4 font-medium">Niveau</th>
                    <th class="p-4 font-medium">Fili&egrave;re</th>
                    <th class="p-4 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="p-4">
                            <div class="font-bold text-gray-800">@item.Nom</div>
                        </td>
                        
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 border border-gray-200">
                                @item.Niveau?.Nom
                            </span>
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-orange-100 text-orange-800 border border-orange-200">
                                @item.Filiere?.Nom
                            </span>
                        </td>
                        <td class="p-4 text-right space-x-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 p-2 rounded-lg transition-colors inline-block" title="D&eacute;tails">
                                <i class="fas fa-info-circle"></i>
                            </a>
                            
                            @if (isAdminOrResp)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="text-yellow-600 hover:text-yellow-900 bg-yellow-50 hover:bg-yellow-100 p-2 rounded-lg transition-colors inline-block" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" method="post" class="inline-block">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors" title="Supprimer" onclick="return confirm('Voulez-vous supprimer cette classe ?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="p-8 text-center text-gray-500">
                            <i class="fas fa-users-slash text-4xl mb-3 text-gray-300"></i>
                            <p>Aucune classe trouv&eacute;e.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

