@model ProjetEMIT.ViewModels.ClasseViewModel

@{
    ViewData["Title"] = "Modifier la Classe";
}

<div class="max-w-3xl mx-auto bg-white shadow-xl rounded-xl border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-emerald-600 to-teal-800 p-6 text-white">
        <h2 class="text-2xl font-bold flex items-center">
            <i class="fas fa-edit mr-3"></i> Modifier la Classe
        </h2>
    </div>
    <div class="p-8">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium bg-red-50 p-3 rounded-lg border border-red-200"></div>
            <input type="hidden" asp-for="Id" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Nom" class="block text-sm font-semibold text-gray-700 mb-2">Nom de la Classe</label>
                    <input asp-for="Nom" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" required />
                    <span asp-validation-for="Nom" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="NiveauId" class="block text-sm font-semibold text-gray-700 mb-2">Niveau</label>
                    <select asp-for="NiveauId" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                        <option value="">-- S&eacute;lectionner le niveau --</option>
                        @foreach (var n in ViewBag.Niveaux)
                        {
                            <option value="@n.Id">@n.Nom</option>
                        }
                    </select>
                    <span asp-validation-for="NiveauId" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="FiliereId" class="block text-sm font-semibold text-gray-700 mb-2">Fili&egrave;re associ&eacute;e</label>
                    <select asp-for="FiliereId" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                        <option value="">-- S&eacute;lectionner la fili&egrave;re --</option>
                        @foreach (var f in ViewBag.Filieres)
                        {
                            <option value="@f.Id">@f.Nom (@f.Code)</option>
                        }
                    </select>
                    <span asp-validation-for="FiliereId" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
            <div class="mt-8 flex items-center justify-end space-x-4 pt-6 border-t border-gray-100">
                <a asp-action="Index" class="px-6 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">Annuler</a>
                <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-emerald-600 hover:bg-emerald-700 rounded-lg shadow-lg shadow-emerald-500/30 transition-all flex items-center">
                    <i class="fas fa-save mr-2"></i> Mettre &agrave; jour
                </button>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
