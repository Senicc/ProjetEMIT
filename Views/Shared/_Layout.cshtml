<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EMIT</title>

    <!-- Bootstrap 5 + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

    <!-- FullCalendar -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary-color: #1e3a8a;
        }
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, #1e3a8a, #0f2b6b);
            color: white;
        }
        .nav-link {
            color: #ddd !important;
            transition: all 0.3s;
        }
        .nav-link:hover, .nav-link.active {
            background-color: rgba(255,255,255,0.15);
            color: white !important;
            border-left: 4px solid #60a5fa;
        }
        .main-content {
            margin-left: 260px;
            padding: 20px;
        }
        .brand {
            font-size: 1.5rem;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="d-flex">
        <!-- ==================== SIDEBAR ==================== -->
        <div class="sidebar p-3" style="width: 260px; position: fixed; height: 100vh; overflow-y: auto;">
            <div class="text-center mb-4">
                <h3 class="brand">
                    <i class="fas fa-university"></i> EMIT
                </h3>
                <p class="small text-light">École de Management et d’Innovation Technologique</p>
            </div>

            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @((ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin") ? "active" : "")" 
                       asp-controller="Admin" asp-action="Index">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item mt-3">
                    <a class="nav-link @((ViewContext.RouteData.Values["Controller"]?.ToString() == "Salle") ? "active" : "")" 
                       asp-controller="Salle" asp-action="Index">
                        <i class="fas fa-door-open"></i> Salles
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @((ViewContext.RouteData.Values["Controller"]?.ToString() == "Enseignant") ? "active" : "")" 
                       asp-controller="Enseignant" asp-action="Index">
                        <i class="fas fa-chalkboard-teacher"></i> Enseignants
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="EmploiDuTemps" asp-action="Index">
                        <i class="fas fa-calendar-alt"></i> Emplois du Temps
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Reservation" asp-action="Index">
                        <i class="fas fa-calendar-check"></i> Réservations
                    </a>
                </li>

                <li class="nav-item mt-3">
                    <a class="nav-link" asp-controller="Matiere" asp-action="Index">
                        <i class="fas fa-book"></i> Matières
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Classe" asp-action="Index">
                        <i class="fas fa-users"></i> Classes & Filieres
                    </a>
                </li>

                @if (User.IsInRole("Administrateur"))
                {
                    <li class="nav-item mt-4">
                        <a class="nav-link" asp-controller="UserManagement" asp-action="Index">
                            <i class="fas fa-user-plus"></i> Gestion Utilisateurs
                        </a>
                    </li>
                }

                <li class="nav-item mt-auto pt-4">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="nav-link text-danger btn btn-link text-start w-100 p-2 border-0"
                                onclick="return confirm('Voulez-vous vraiment vous déconnecter ?');">
                            <i class="fas fa-sign-out-alt"></i> Déconnexion
                        </button>
                    </form>
                </li>
            </ul>
        </div>

        <!-- ==================== CONTENU PRINCIPAL ==================== -->
        <div class="main-content flex-grow-1">
            <!-- Navbar Top -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4 px-4">
                <div class="container-fluid">
                    <span class="navbar-brand fw-bold text-primary">Système de Gestion EMIT</span>
                    
                    <div class="d-flex align-items-center">
                        <span class="me-3 text-muted">
                            <i class="fas fa-user-circle"></i> 
                            @User.Identity?.Name
                        </span>
                        @{
                            var roles = User.FindAll(System.Security.Claims.ClaimTypes.Role).Select(c => c.Value).ToList();
                        }
                        @if (roles.Count > 0)
                        {
                            <span class="badge bg-primary">@string.Join(", ", roles)</span>
                        }
                    </div>
                </div>
            </nav>

            <!-- Messages TempData -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Contenu des vues -->
            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>