@model EditRolesViewModel
@{
    ViewData["Title"] = "Modifier les rôles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Rôles — @Model.Email</h2>

<form asp-action="EditRoles" method="post">
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="Email" />

    <div class="mb-3">
        @foreach (var role in ViewBag.AllRoles as List<string> ?? new List<string>())
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role"
                       id="role_@role" @(Model.CurrentRoles.Contains(role) ? "checked" : null) />
                <label class="form-check-label" for="role_@role">@role</label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Retour</a>
</form>
