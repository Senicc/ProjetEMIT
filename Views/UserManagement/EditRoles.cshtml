@model ProjetEMIT.ViewModels.EditRolesViewModel

@{
    ViewData["Title"] = "Gestion des r&ocirc;les";
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
}

<div class="max-w-2xl mx-auto bg-white shadow-xl rounded-xl border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-indigo-800 p-6 text-white">
        <h2 class="text-2xl font-bold flex items-center">
            <i class="fas fa-user-shield mr-3"></i> G&eacute;rer les r&ocirc;les
        </h2>
        <p class="text-blue-100 mt-2 opacity-90">Affectez ou retirez des autorisations pour : <strong>@Model.Email</strong></p>
    </div>

    <div class="p-8">
        <form asp-action="EditRoles" method="post">
            <input type="hidden" asp-for="UserId" />
            
            <div class="space-y-4">
                @foreach (var role in allRoles)
                {
                    bool isSelected = Model.CurrentRoles.Contains(role);
                    <div class="flex items-center p-4 bg-gray-50 border border-gray-200 rounded-lg">
                        <input type="checkbox" name="SelectedRoles" value="@role" @(isSelected ? "checked" : "") class="w-5 h-5 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500" id="role_@role" />
                        <label for="role_@role" class="ml-3 text-sm font-medium text-gray-700 cursor-pointer w-full">
                            @role
                        </label>
                    </div>
                }
            </div>

            <div class="mt-8 flex items-center justify-end space-x-4 pt-6 border-t border-gray-100">
                <a asp-action="Index" class="px-6 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                    Annuler
                </a>
                <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg shadow-lg shadow-blue-500/30 transition-all flex items-center">
                    <i class="fas fa-save mr-2"></i> Enregistrer les r&ocirc;les
                </button>
            </div>
        </form>
    </div>
</div>
