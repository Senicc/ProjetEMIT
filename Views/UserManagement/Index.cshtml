@model IEnumerable<ProjetEMIT.ViewModels.UserViewModel>
@{
    ViewData["Title"] = "Gestion des Utilisateurs";
}

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h2 class="text-2xl font-bold text-gray-800">
                <i class="fas fa-users-cog text-blue-600 mr-2"></i> Utilisateurs
            </h2>
            <p class="text-sm text-gray-500 mt-1">G&eacute;rez les comptes et les droits d'acc&egrave;s de l'application.</p>
        </div>
        <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium shadow-md shadow-blue-500/20 transition-all flex items-center text-sm">
            <i class="fas fa-user-plus mr-2"></i> Nouvel utilisateur
        </a>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 text-gray-600 text-sm border-b border-gray-200">
                        <th class="py-4 px-6 font-semibold">Nom Complet</th>
                        <th class="py-4 px-6 font-semibold">Email</th>
                        <th class="py-4 px-6 font-semibold">R&ocirc;les</th>
                        <th class="py-4 px-6 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var u in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="py-4 px-6 font-medium text-gray-800">
                                <div class="flex items-center">
                                    <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold mr-3">
                                        @u.Prenom.Substring(0, 1)@u.Nom.Substring(0, 1)
                                    </div>
                                    @u.Prenom @u.Nom
                                </div>
                            </td>
                            <td class="py-4 px-6 text-sm text-gray-500">@u.Email</td>
                            <td class="py-4 px-6">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var role in u.Roles)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
                                            @role
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="py-4 px-6 text-right space-x-2">
                                <a asp-action="EditRoles" asp-route-id="@u.Id" class="inline-flex items-center justify-center px-3 py-1.5 rounded bg-yellow-50 text-yellow-600 hover:bg-yellow-100 transition-colors text-sm font-medium" title="G&eacute;rer les r&ocirc;les">
                                    <i class="fas fa-key mr-1"></i> R&ocirc;les
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
