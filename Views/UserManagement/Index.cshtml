@model IEnumerable<UserViewModel>
@{
    ViewData["Title"] = "Utilisateurs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users-cog"></i> Utilisateurs</h2>
    <a asp-action="Create" class="btn btn-success"><i class="fas fa-user-plus"></i> Nouvel utilisateur</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nom</th>
            <th>Email</th>
            <th>Rôles</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Prenom @u.Nom</td>
            <td>@u.Email</td>
            <td>@string.Join(", ", u.Roles)</td>
            <td>
                <a asp-action="EditRoles" asp-route-id="@u.Id" class="btn btn-sm btn-warning">Rôles</a>
            </td>
        </tr>
    }
    </tbody>
</table>
