@model ProjetEMIT.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = "Cr&eacute;er un utilisateur";
    var roles = ViewBag.Roles as List<string> ?? new List<string>();
}

<div class="max-w-3xl mx-auto bg-white shadow-xl rounded-xl border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 p-6 text-white">
        <h2 class="text-2xl font-bold flex items-center">
            <i class="fas fa-user-plus mr-3"></i> Nouvel Utilisateur
        </h2>
        <p class="text-blue-100 mt-2 opacity-90">Cr&eacute;ez un nouveau compte d'acc&egrave;s au syst&egrave;me.</p>
    </div>

    <div class="p-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-red-500 mb-6 text-sm font-medium bg-red-50 p-4 rounded-lg border border-red-200"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Nom -->
                <div>
                    <label asp-for="Nom" class="block text-sm font-semibold text-gray-700 mb-2">Nom</label>
                    <input asp-for="Nom" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" required placeholder="Nom de famille" />
                    <span asp-validation-for="Nom" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Pr&eacute;nom -->
                <div>
                    <label asp-for="Prenom" class="block text-sm font-semibold text-gray-700 mb-2">Pr&eacute;nom</label>
                    <input asp-for="Prenom" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" required placeholder="Pr&eacute;nom" />
                    <span asp-validation-for="Prenom" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-2">Adresse E-mail</label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" required placeholder="email@domaine.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Mot de passe -->
                <div>
                    <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-2">Mot de passe</label>
                    <input asp-for="Password" type="password" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" required placeholder="8 caract&egrave;res minimum" />
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- R&ocirc;le -->
                <div>
                    <label asp-for="Role" class="block text-sm font-semibold text-gray-700 mb-2">R&ocirc;le initial</label>
                    <select asp-for="Role" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        <option value="">-- S&eacute;lectionner un r&ocirc;le (optionnel) --</option>
                        @foreach (var r in roles)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>

                <!-- Enseignant Li&eacute; -->
                <div>
                    <label asp-for="EnseignantId" class="block text-sm font-semibold text-gray-700 mb-2 flex items-center justify-between">
                        <span>ID Enseignant Li&eacute;</span>
                        <span class="text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded">Optionnel</span>
                    </label>
                    <input asp-for="EnseignantId" type="number" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" placeholder="Lier &agrave; un profil Enseignant" />
                    <p class="text-xs text-gray-500 mt-1">Pour relier ce compte &agrave; un enseignant de l'application.</p>
                </div>
            </div>

            <div class="mt-8 flex items-center justify-end space-x-4 pt-6 border-t border-gray-100">
                <a asp-action="Index" class="px-6 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                    Annuler
                </a>
                <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg shadow-lg shadow-blue-500/30 transition-all flex items-center">
                    <i class="fas fa-user-check mr-2"></i> Cr&eacute;er l'utilisateur
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
