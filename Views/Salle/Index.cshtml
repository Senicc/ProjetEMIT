@model IEnumerable<ProjetEMIT.Models.Salle>

@{
    ViewData["Title"] = "Gestion des Salles";
    var isAdminOrResp = User.IsInRole("Administrateur") || User.IsInRole("ResponsablePedagogique");
}

<div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
    <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-gray-50/50">
        <div>
            <h2 class="text-xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-door-open mr-2 text-blue-600"></i> Salles de Cours
            </h2>
            <p class="text-sm text-gray-500 mt-1">Consultez et g&eacute;rez les salles disponibles dans l'&eacute;tablissement.</p>
        </div>
        
        @if (isAdminOrResp)
        {
            <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium shadow-md shadow-blue-500/20 transition-all flex items-center">
                <i class="fas fa-plus mr-2"></i> Ajouter une Salle
            </a>
        }
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider border-b border-gray-200">
                    <th class="p-4 font-medium">Nom / Num&eacute;ro</th>
                    <th class="p-4 font-medium">Type</th>
                    <th class="p-4 font-medium text-center">Capacit&eacute;</th>
                    <th class="p-4 font-medium">Localisation</th>
                    <th class="p-4 font-medium text-center">Disponibilit&eacute;</th>
                    <th class="p-4 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="p-4">
                            <div class="font-bold text-gray-800">@item.NomSalle</div>
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-purple-100 text-purple-800 border border-purple-200">
                                @item.TypeSalle
                            </span>
                        </td>
                        <td class="p-4 text-center font-medium text-gray-600">
                            <i class="fas fa-users text-gray-400 mr-1"></i> @item.Capacite
                        </td>
                        <td class="p-4 text-gray-600">
                            <i class="fas fa-map-marker-alt text-red-400 mr-1"></i> @item.Localisation
                        </td>
                        <td class="p-4 text-center">
                            @if (item.EstDisponible)
                            {
                                <span class="text-green-500"><i class="fas fa-check-circle text-lg"></i></span>
                            }
                            else
                            {
                                <span class="text-red-500"><i class="fas fa-times-circle text-lg"></i></span>
                            }
                        </td>
                        <td class="p-4 text-right space-x-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 p-2 rounded-lg transition-colors inline-block" title="D&eacute;tails">
                                <i class="fas fa-info-circle"></i>
                            </a>
                            
                            @if (isAdminOrResp)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="text-yellow-600 hover:text-yellow-900 bg-yellow-50 hover:bg-yellow-100 p-2 rounded-lg transition-colors inline-block" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" method="post" class="inline-block">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors" title="Supprimer" onclick="return confirm('Voulez-vous vraiment supprimer cette salle ?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="p-8 text-center text-gray-500">
                            <i class="fas fa-door-closed text-4xl mb-3 text-gray-300"></i>
                            <p>Aucune salle n'a &eacute;t&eacute; trouv&eacute;e.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
