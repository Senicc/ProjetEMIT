@model ProjetEMIT.Models.Salle
@{
    ViewData["Title"] = "Modifier salle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Modifier la salle</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="NomSalle" class="form-label"></label>
        <input asp-for="NomSalle" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Capacite" class="form-label"></label>
        <input asp-for="Capacite" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="TypeSalle" class="form-label"></label>
        <input asp-for="TypeSalle" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Localisation" class="form-label"></label>
        <input asp-for="Localisation" class="form-control" />
    </div>
    <div class="form-check mb-3">
        <input asp-for="EstDisponible" class="form-check-input" />
        <label asp-for="EstDisponible" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
