@model ProjetEMIT.ViewModels.MatiereViewModel

@{
    ViewData["Title"] = "Ajouter une Mati&egrave;re";
}

<div class="max-w-3xl mx-auto bg-white shadow-xl rounded-xl border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-teal-500 to-teal-700 p-6 text-white">
        <h2 class="text-2xl font-bold flex items-center">
            <i class="fas fa-book-open mr-3"></i> Nouvelle Mati&egrave;re
        </h2>
        <p class="text-teal-100 mt-2 opacity-90">Enregistrez un nouveau module d'enseignement.</p>
    </div>

    <div class="p-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium bg-red-50 p-3 rounded-lg border border-red-200"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Code -->
                <div>
                    <label asp-for="Code" class="block text-sm font-semibold text-gray-700 mb-2">Code</label>
                    <input asp-for="Code" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all" required placeholder="Ex: INF101" />
                    <span asp-validation-for="Code" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Nom -->
                <div>
                    <label asp-for="Nom" class="block text-sm font-semibold text-gray-700 mb-2">Nom de la mati&egrave;re</label>
                    <input asp-for="Nom" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all" required placeholder="Ex: Algorithmique" />
                    <span asp-validation-for="Nom" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Coefficient -->
                <div>
                    <label asp-for="Coefficient" class="block text-sm font-semibold text-gray-700 mb-2">Coefficient</label>
                    <input asp-for="Coefficient" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all" required type="number" min="1" placeholder="Ex: 3" />
                    <span asp-validation-for="Coefficient" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Heures -->
                <div>
                    <label asp-for="NbreHeures" class="block text-sm font-semibold text-gray-700 mb-2">Nombre d'heures</label>
                    <input asp-for="NbreHeures" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all" required type="number" min="1" placeholder="Ex: 40" />
                    <span asp-validation-for="NbreHeures" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Fili&egrave;re -->
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="FiliereId" class="block text-sm font-semibold text-gray-700 mb-2">Fili&egrave;re associ&eacute;e</label>
                    <select asp-for="FiliereId" class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all" required>
                        <option value="">-- S&eacute;lectionner la fili&egrave;re --</option>
                        @foreach (var f in ViewBag.Filieres)
                        {
                            <option value="@f.Id">@f.Nom (@f.Code)</option>
                        }
                    </select>
                    <span asp-validation-for="FiliereId" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Enseignants (Multiple) -->
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="SelectedEnseignantsIds" class="block text-sm font-semibold text-gray-700 mb-2">Enseignants assign&eacute;s</label>
                    <select asp-for="SelectedEnseignantsIds" multiple class="w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all" style="min-height: 120px;">
                        @foreach (var e in ViewBag.Enseignants)
                        {
                            <option value="@e.Id">@e.Prenom @e.Nom - @e.Specialite</option>
                        }
                    </select>
                    <p class="text-xs text-gray-500 mt-1">Maintenez la touche Ctrl (ou Cmd sur Mac) pour s&eacute;lectionner plusieurs enseignants.</p>
                </div>
            </div>

            <div class="mt-8 flex items-center justify-end space-x-4 pt-6 border-t border-gray-100">
                <a asp-action="Index" class="px-6 py-2.5 text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">
                    Annuler
                </a>
                <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 rounded-lg shadow-lg shadow-teal-500/30 transition-all flex items-center">
                    <i class="fas fa-save mr-2"></i> Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
