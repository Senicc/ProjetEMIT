@model IEnumerable<ProjetEMIT.Models.Matiere>

@{
    ViewData["Title"] = "Gestion des Mati&egrave;res";
    var isAdminOrResp = User.IsInRole("Administrateur") || User.IsInRole("ResponsablePedagogique");
}

<div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
    <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-gray-50/50">
        <div>
            <h2 class="text-xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-book mr-2 text-emerald-600"></i> Mati&egrave;res Enseign&eacute;es
            </h2>
            <p class="text-sm text-gray-500 mt-1">Programme des cours et mati&egrave;res dispens&eacute;es.</p>
        </div>
        
        @if (isAdminOrResp)
        {
            <a asp-action="Create" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg font-medium shadow-md shadow-emerald-500/20 transition-all flex items-center">
                <i class="fas fa-plus mr-2"></i> Ajouter une Mati&egrave;re
            </a>
        }
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider border-b border-gray-200">
                    <th class="p-4 font-medium">Code</th>
                    <th class="p-4 font-medium">Nom de la Mati&egrave;re</th>
                    <th class="p-4 font-medium text-center">Volume Horaire</th>
                    <th class="p-4 font-medium text-center">Cr&eacute;dits</th>
                    <th class="p-4 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="p-4">
                            <span class="font-mono font-semibold text-gray-700 bg-gray-100 px-2 py-1 rounded">@item.Code</span>
                        </td>
                        <td class="p-4 font-bold text-gray-800">
                            @item.Nom
                        </td>
                        <td class="p-4 text-center text-gray-600">
                            <i class="far fa-clock text-gray-400 mr-1"></i> @item.NbreHeures h
                        </td>
                        <td class="p-4 text-center font-medium">
                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-emerald-100 text-emerald-700">
                                @item.Coefficient
                            </span>
                        </td>
                        <td class="p-4 text-right space-x-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 p-2 rounded-lg transition-colors inline-block" title="D&eacute;tails">
                                <i class="fas fa-info-circle"></i>
                            </a>
                            
                            @if (isAdminOrResp)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="text-yellow-600 hover:text-yellow-900 bg-yellow-50 hover:bg-yellow-100 p-2 rounded-lg transition-colors inline-block" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" method="post" class="inline-block">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors" title="Supprimer" onclick="return confirm('Voulez-vous supprimer cette mati&egrave;re ?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="p-8 text-center text-gray-500">
                            <i class="fas fa-book-open text-4xl mb-3 text-gray-300"></i>
                            <p>Aucune mati&egrave;re trouv&eacute;e.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

